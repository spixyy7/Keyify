# ================================================================
# Railway backend only - secrets stay here, never in Vercel frontend
# ================================================================

# Supabase (Railway only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT (Railway only)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email (Railway only - Gmail App Password, not regular password)
EMAIL_USER=yourmail@gmail.com
EMAIL_PASS=your-gmail-app-password
ENABLE_SMTP_FALLBACK=false

# App / CORS (Railway only)
PORT=3001
FRONTEND_URL=https://your-keyify-site.vercel.app
FRONTEND_URLS=https://your-keyify-site.vercel.app,https://your-production-domain.com
ALLOW_VERCEL_PREVIEWS=false
ALLOW_LOCALHOST_CORS=false
BACKEND_URL=https://your-backend.railway.app

# Local + public example during development:
# FRONTEND_URLS=https://your-keyify-site.vercel.app,http://localhost:63342,http://127.0.0.1:63342
# If you want localhost access without listing each local origin manually, set:
# ALLOW_LOCALHOST_CORS=true

# Google OAuth + Gmail API (Railway only)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/auth/google/callback
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# SQL Editor PIN (Railway only, super-admin only)
SQL_MASTER_PIN=your-secure-pin

# Stripe secret values (Railway only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin notifications:
# Every admin with receive_purchase_notifications = true gets purchase emails.
# Super-admins with empty permissions inherit them automatically.

# ================================================================
# Vercel frontend - only public values
# ================================================================
# This static frontend currently reads public config from config.js:
#   window.KEYIFY_CONFIG.API_URL -> https://your-backend.railway.app/api
#   window.KEYIFY_STRIPE_PK      -> pk_live_... or pk_test_...
# Never put these on Vercel:
#   SUPABASE_SERVICE_KEY, JWT_SECRET, EMAIL_PASS, SQL_MASTER_PIN,
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, GOOGLE_CLIENT_SECRET
