# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email (Gmail – use App Password, not regular password)
EMAIL_USER=yourmail@gmail.com
EMAIL_PASS=your-gmail-app-password
ENABLE_SMTP_FALLBACK=false

# App
PORT=3001
FRONTEND_URL=https://your-keyify-site.netlify.app
FRONTEND_URLS=https://your-keyify-site.netlify.app,https://your-production-domain.com
ALLOW_VERCEL_PREVIEWS=true

# Google OAuth + Gmail API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/auth/google/callback
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token   # run /api/auth/gmail-setup once to get this
BACKEND_URL=https://your-backend.railway.app   # used for gmail-setup callback

# SQL Editor PIN (super-admin only)
SQL_MASTER_PIN=your-secure-pin

# Stripe (ostavi prazno – plaćanje karticom je trenutno onemogućeno)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin notifikacije: NE koristiti ADMIN_EMAIL.
# Svaki admin koji ima permisiju "receive_purchase_notifications" = true prima email o kupovinama.
# Super-admini (prazne permisije) primaju automatski.
